# Template for a Software Deployment Pattern.
schemaVersion: "1.0"
id: software-deployment.<product-slug>
type: software_deployment_pattern
name: <Product or System Name>
description: <Product-specific deployment reality description.>
version: 1.0.0
catalogStatus: stub
lifecycleStatus: pre-invest
owner:
  team: <owning-team>
  contact: <team-or-person@example.com>
tags:
  - <product-slug>
# Declare only profiles this artifact explicitly claims.
controlEnforcementProfiles: []
controlImplementations: []
followsReferenceArchitecture: reference-architecture.<pattern-slug>
architecturalDecisions:
  availabilityRequirement: <Business availability requirement.>
  dataClassification: <Data classification.>
  failureDomain: <Product-level failure domain.>
  patternDeviations: <Intentional deviations from the selected Reference Architecture, or none.>
serviceGroups:
  - name: <Service Group Name>
    deploymentTarget: <Actual deployment target.>
    standards:
      - ref: <existing-standard-id>
        diagramTier: <presentation|application|data|utility>
        intent: <ha|sa>
        notes: <How this block is used by the product.>
    externalInteractions:
      - name: <External System>
        type: external
        capabilities:
          - <capability-id>
        notes: <Runtime dependency or interaction.>
decisionRecords:
  - ref: decision.<product-slug>.001
