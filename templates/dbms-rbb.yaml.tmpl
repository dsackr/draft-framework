# Template for a Database Service RBB.
schemaVersion: "1.0"
id: rbb.service.dbms.<engine-version>
type: rbb
name: <Database Engine Version> DBMS Service
description: <Reusable database service description.>
version: 1.0.0
catalogStatus: stub
lifecycleStatus: pre-invest
owner:
  team: <owning-team>
  contact: <team-or-person@example.com>
tags:
  - service
  - dbms
category: service
serviceCategory: database
satisfiesODC:
  - odc.service
  - odc.service.dbms
# Declare only profiles this RBB explicitly claims.
complianceProfiles: []
controlImplementations: []
hostRbb: rbb.host.<os>.<platform>.<variant>
functionAbb: abb.software.<database-engine-version>
architecturalDecisions:
  serviceAuthentication: <How administrators and service identities authenticate.>
  secretsManagement: <How database credentials and connection secrets are stored.>
  serviceLogging: <How database audit and engine logs are delivered.>
  healthWelfareMonitoring: <How database service health is monitored.>
  availabilityModel: <Availability model, such as clustered, replicated, or standalone.>
  scalabilityModel: <Scale-up, scale-out, read replica, or shard model.>
  recoverabilityModel: <How failed nodes or services are recovered.>
  failureDomain: <Scope of impact from database service failure.>
  backup:
    strategy: <Backup strategy.>
    rto: <Recovery time objective.>
    rpo: <Recovery point objective.>
  ha:
    mechanism: <HA or replication mechanism.>
  encryption:
    atRest: <Encryption-at-rest posture.>
  accessControl:
    model: <Administrative and application access control model.>
internalComponents:
  - ref: rbb.host.<os>.<platform>.<variant>
    role: host
  - ref: abb.software.<database-engine-version>
    role: function
externalInteractions:
  - name: <Backup Platform>
    notes: <Off-host backup target and retention management.>
    capabilities:
      - data-persistence
  - name: <Database Monitoring>
    notes: <Database telemetry and alerting.>
    capabilities:
      - monitoring
