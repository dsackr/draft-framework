# Template for a PaaS Service RBB.
schemaVersion: "1.0"
id: paas.<vendor-product>
type: rbb
category: service
serviceCategory: paas
name: <PaaS Service Name>
description: <Vendor-managed platform service description.>
version: 1.0.0
catalogStatus: stub
lifecycleStatus: pre-invest
owner:
  team: <owning-team>
  contact: <team-or-person@example.com>
tags:
  - paas
vendor: <Vendor>
capabilities:
  - <capability-id>
# Declare only profiles this RBB explicitly claims.
complianceProfiles: []
controlImplementations: []
vendorSLA: <Vendor SLA or support posture.>
authenticationModel: <iam|api-key|other>
complianceCerts:
  - <certification-name>
architecturalDecisions:
  resilienceModel: <Resilience posture the adopter depends on.>
  dataBoundary: <Whether data remains inside the organization's cloud boundary.>
  failureDomain: <Failure domain introduced by this PaaS service.>
