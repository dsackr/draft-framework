# Template for a Control Enforcement Profile that maps controls to DRAFT semantics.
schemaVersion: "1.0"
id: control-enforcement.<profile-slug>
type: control_enforcement_profile
name: <Profile Name>
description: <How the control framework applies to DRAFT objects.>
version: 1.0.0
controls: controls.<framework-slug>
catalogStatus: stub
lifecycleStatus: pre-invest
owner:
  team: <owning-team>
  contact: <team-or-person@example.com>
tags:
  - control-enforcement-profile
controlSemantics:
  - controlId: <CONTROL-ID>
    appliesTo:
      - <host_standard|service_standard|database_standard|product_service|paas_service_standard|saas_service_standard|reference_architecture|software_deployment_pattern|appliance_component>
    requirementMode: <mandatory|conditional>
    validAnswerTypes:
      - <technologyComponent|technologyComponentConfiguration|deploymentConfiguration|externalInteraction|architecturalDecision|field>
    relatedCapability: <optional-capability-id>
    naAllowed: false
    notes: <How this control should be answered in DRAFT.>
