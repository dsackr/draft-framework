# Template for a general Service RBB.
schemaVersion: "1.0"
id: rbb.service.<service-slug>
type: rbb
name: <Service Name>
description: <Reusable service description.>
version: 1.0.0
catalogStatus: stub
lifecycleStatus: pre-invest
owner:
  team: <owning-team>
  contact: <team-or-person@example.com>
tags:
  - service
category: service
serviceCategory: general
satisfiesODC:
  - odc.service
# Declare only profiles this RBB explicitly claims.
complianceProfiles: []
controlImplementations: []
hostRbb: rbb.host.<os>.<platform>.<variant>
functionAbb: abb.software.<vendor-product-version>
architecturalDecisions:
  serviceAuthentication: <How administrators or service identities authenticate.>
  secretsManagement: <How secrets, keys, tokens, or certificates are stored and accessed.>
  serviceLogging: <How service logs are produced and delivered beyond host logs.>
  healthWelfareMonitoring: <How service health and telemetry are monitored.>
  availabilityModel: <Availability model.>
  scalabilityModel: <Capacity growth model.>
  recoverabilityModel: <Recovery model.>
  failureDomain: <Scope of impact from service failure.>
internalComponents:
  - ref: rbb.host.<os>.<platform>.<variant>
    role: host
  - ref: abb.software.<vendor-product-version>
    role: function
externalInteractions:
  - name: <Service Monitoring>
    notes: <Service-level monitoring beyond the host baseline.>
    capabilities:
      - monitoring
