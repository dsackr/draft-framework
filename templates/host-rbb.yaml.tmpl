# Template for a Host RBB.
schemaVersion: "1.0"
id: rbb.host.<os>.<platform>.<variant>
type: rbb
name: <Host Name>
description: <Standardized host platform description.>
version: 1.0.0
catalogStatus: stub
lifecycleStatus: pre-invest
owner:
  team: <owning-team>
  contact: <team-or-person@example.com>
tags:
  - host
category: host
satisfiesODC:
  - odc.host
# Declare only profiles this RBB explicitly claims.
complianceProfiles: []
controlImplementations: []
osAbb: abb.os.<vendor-product-version>
hardwareAbb: abb.hardware.<vendor-product>
internalComponents:
  - ref: abb.os.<vendor-product-version>
    role: os
  - ref: abb.hardware.<vendor-product>
    role: hardware
externalInteractions:
  - name: <Authentication Platform>
    notes: <How administrators and service identities authenticate.>
    capabilities:
      - authentication
  - name: <Logging Platform>
    notes: <How host logs are collected.>
    capabilities:
      - logging
  - name: <Monitoring Platform>
    notes: <How host health and welfare are monitored.>
    capabilities:
      - monitoring
  - name: <Security Monitoring Platform>
    notes: <How security telemetry is collected.>
    capabilities:
      - security
  - name: <Patch Management Platform>
    notes: <How operating system and host patching is governed.>
    capabilities:
      - patch-management
