schemaVersion: "1.0"
workspace:
  name: <company-draft-workspace>

repository:
  provider: github
  owner: <github-org>
  name: <private-repo>
  defaultBranch: <default-branch>

framework:
  source: https://github.com/dsackr/draft-framework.git
  vendoredPath: .draft/framework
  updatePolicy: explicit
  updateWorkflow: enabled

paths:
  catalog: catalog
  configurations: configurations

requirements:
  activeRequirementGroups: []
  requireActiveRequirementGroupDisposition: false
